{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/",
      "destination": "/static/index.html"
    },
    {
      "source": "/((?!static/).*)",
      "destination": "/api/index.py"
    }
  ]
}
